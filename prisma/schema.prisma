generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String                   @id @default(uuid())
  email        String                   @unique
  passwordHash String
  role         String
  createdAt    DateTime                 @default(now())
  bookings     Booking[]                @relation("VendorBookings")
  festivals    Festival[]               @relation("OrganizerFestivals")
  participants NegotiationParticipant[]
  profile      Profile?
}

model Profile {
  id            String  @id @default(uuid())
  userId        String  @unique
  companyName   String
  contactPhone  String?
  category      String?
  verified      Boolean @default(false)
  metadata      String?
  adminFeedback String?
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Festival {
  id                   String    @id @default(uuid())
  organizerId          String
  name                 String
  collegeName          String
  location             String
  startDate            DateTime
  endDate              DateTime
  expectedFootfall     Int
  artistLineup         String
  demographics         String?
  opportunityScore     Int       @default(50)
  layoutMapUrl         String?
  bannerUrl            String?
  galleryUrls          String?
  defaultStallPrice    Float     @default(35000.0)
  mapDimensions        String?
  published            Boolean   @default(false)
  createdAt            DateTime  @default(now())
  type                 String    @default("FESTIVAL")
  timeline             String    @default("")
  instagramUrl         String?
  decks                String?
  proposedArtistLineup String?
  mapLocked            Boolean   @default(false)
  mapLayoutHistory     String?
  mediaHistory         String?
  bookings             Booking[]
  organizer            User      @relation("OrganizerFestivals", fields: [organizerId], references: [id], onDelete: Cascade)
  stalls               Stall[]
}

model Stall {
  id               String    @id @default(uuid())
  festivalId       String
  festivalName     String    @default("")
  stallNumber      String
  dimensions       String
  basePrice        Float
  publicPrice      Float
  commissionAmount Float     @default(0.0)
  status           String
  coordinates      String
  expectedTraffic  Float
  visibilityScore  Float
  minSales         Float
  maxSales         Float
  description      String?
  powerGrid        String    @default("Standard (15A)")
  bookings         Booking[]
  festival         Festival  @relation(fields: [festivalId], references: [id], onDelete: Cascade)
}

model Booking {
  id          String       @id @default(uuid())
  festivalId  String
  vendorId    String
  stallId     String
  status      String
  finalPrice  Float
  contractUrl String?
  createdAt   DateTime     @default(now())
  stall       Stall        @relation(fields: [stallId], references: [id], onDelete: Cascade)
  vendor      User         @relation("VendorBookings", fields: [vendorId], references: [id], onDelete: Cascade)
  festival    Festival     @relation(fields: [festivalId], references: [id], onDelete: Cascade)
  negotiation Negotiation?
}

model Negotiation {
  id           String                   @id @default(uuid())
  bookingId    String                   @unique
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  booking      Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  messages     NegotiationMessage[]
  participants NegotiationParticipant[]
}

model NegotiationParticipant {
  id            String      @id @default(uuid())
  negotiationId String
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
}

model NegotiationMessage {
  id            String      @id @default(uuid())
  negotiationId String
  senderId      String
  content       String
  proposedPrice Float?
  attachmentUrl String?
  createdAt     DateTime    @default(now())
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
}

model Review {
  id           String   @id @default(uuid())
  festivalId   String
  festivalName String
  userId       String
  userName     String
  role         String
  rating       Int
  comment      String
  createdAt    DateTime @default(now())
}

model Report {
  id        String   @id @default(uuid())
  type      String
  period    String
  title     String
  data      String
  createdAt DateTime @default(now())
}
